            Utility:Create("UICorner", {Parent = ripple, CornerRadius = UDim.new(1, 0)})
            
            Utility:Tween(ripple, {Size = UDim2.new(0, btn.AbsoluteSize.X * 2, 0, btn.AbsoluteSize.X * 2), BackgroundTransparency = 1}, 0.4)
            task.delay(0.4, function() ripple:Destroy() end)
            
            cb()
        end)
    end
    
