        function selfDrop:Refresh(newOpts)
            opts = newOpts
            for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
            
            local totalHeight = 0
            for i, o in ipairs(opts) do
                local obtn = Utility:Create("TextButton", {
                    Parent = Scroll,
                    Size = UDim2.new(1, 0, 0, 35),
                    BackgroundColor3 = Theme.ElementBg,
                    AutoButtonColor = false,
                    Text = "  " .. o,
                    TextColor3 = Theme.TextDark,
                    TextSize = 13,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 7
                })
                
                obtn.MouseEnter:Connect(function() Utility:Tween(obtn, {BackgroundColor3 = Theme.ElementHover, TextColor3 = Theme.Text}) end)
                obtn.MouseLeave:Connect(function() Utility:Tween(obtn, {BackgroundColor3 = Theme.ElementBg, TextColor3 = Theme.TextDark}) end)
                
                obtn.MouseButton1Click:Connect(function()
                    val = o
                    btn.TextLabel.Text = dName .. " - " .. val
                    cb({val})
                    open = false
                    Utility:Tween(Icon, {Rotation = 0})
                    Utility:Tween(DropList, {Size = UDim2.new(1, 0, 0, 0)})
                    Utility:Tween(dropStroke, {Transparency = 1})
                end)
                totalHeight = totalHeight + 37
            end
            
            Scroll.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
            if open then
                local tH = math.clamp(totalHeight, 0, 150)
                Utility:Tween(DropList, {Size = UDim2.new(1, 0, 0, tH)})
            end
        end
        
        selfDrop:Refresh(opts)
        
        btn.MouseButton1Click:Connect(function()
            open = not open
            Utility:Tween(Icon, {Rotation = open and 180 or 0})
            if open then
                dropStroke.Transparency = 0
                Utility:Tween(DropList, {Size = UDim2.new(1, 0, 0, math.clamp(#opts * 37, 0, 150))})
            else
                Utility:Tween(DropList, {Size = UDim2.new(1, 0, 0, 0)})
                Utility:Tween(dropStroke, {Transparency = 1})
            end
        end)
        
        return selfDrop
    end
    
