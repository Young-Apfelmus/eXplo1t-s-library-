        Utility:Create("UIStroke", {Parent = mobileBtn, Color = Theme.Stroke, Thickness = 1})
        
        local mDragging, mDragInput, mDragStart, mStartPos
        mobileBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                mDragging = true
                mDragStart = input.Position
                mStartPos = mobileBtn.Position
            end
        end)
        mobileBtn.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                mDragInput = input
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if input == mDragInput and mDragging then
                local delta = input.Position - mDragStart
                mobileBtn.Position = UDim2.new(mStartPos.X.Scale, mStartPos.X.Offset + delta.X, mStartPos.Y.Scale, mStartPos.Y.Offset + delta.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                mDragging = false
                local delta = input.Position - mDragStart
                if delta.Magnitude < 5 then
                    -- Trigger visual feedback
                    Utility:Tween(mobileBtn, {Size = UDim2.new(0, 40, 0, 40)}, 0.1, Enum.EasingStyle.Sine)
                    task.delay(0.1, function() Utility:Tween(mobileBtn, {Size = UDim2.new(0, 45, 0, 45)}, 0.2) end)
                    ToggleUI()
                end
            end
        end)
    end
    
