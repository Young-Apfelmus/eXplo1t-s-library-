        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    local NDesc = Utility:Create("TextLabel", {
        Parent = NContent,
        Size = UDim2.new(1, -30, 0, 30),
        Position = UDim2.new(0, 25, 0, 30),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Theme.TextDark,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        TextYAlignment = Enum.TextYAlignment.Top
    })
    
    NFrame.Size = UDim2.new(1, 0, 0, math.clamp(NDesc.TextBounds.Y + 45, 70, 200))
    
    Utility:Tween(NContent, {Position = UDim2.new(0, 0, 0, 0)}, 0.4, Enum.EasingStyle.Back)
    
    task.spawn(function()
        task.wait(duration)
        Utility:Tween(NContent, {Position = UDim2.new(1, 50, 0, 0)}, 0.4, Enum.EasingStyle.Back)
        task.wait(0.4)
        Utility:Tween(NFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
        task.wait(0.2)
        NFrame:Destroy()
    end)
end

function UI:CreateTab(name, iconId)
    local tab = {}
    
    -- Tab Button
    tab.Button = Utility:Create("TextButton", {
        Parent = self.TabList,
        Size = UDim2.new(1, -16, 0, 32),
        BackgroundColor3 = Theme.Sidebar,
        AutoButtonColor = false,
        Text = name,
        TextColor3 = Theme.TextDark,
        TextSize = 13,
        Font = Enum.Font.GothamMedium
    })
    Utility:Create("UICorner", {Parent = tab.Button, CornerRadius = UDim.new(0, 6)})
    
    local Indicator = Utility:Create("Frame", {
        Parent = tab.Button,
        Size = UDim2.new(0, 3, 0, 0),
        Position = UDim2.new(0, 5, 0.5, 0),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        AnchorPoint = Vector2.new(0, 0.5)
    })
    Utility:Create("UICorner", {Parent = Indicator, CornerRadius = UDim.new(1, 0)})
    
    -- Tab Content
    tab.Content = Utility:Create("ScrollingFrame", {
        Parent = self.Container,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Theme.Scrollbar,
        Visible = false
    })
    
    -- PADDING FIX: Move elements away from the very left edge and give them breathing room
    Utility:Create("UIPadding", {
        Parent = tab.Content,
        PaddingTop = UDim.new(0, 15),
        PaddingBottom = UDim.new(0, 15),
        PaddingLeft = UDim.new(0, 15),
        PaddingRight = UDim.new(0, 15)
    })
    
    local ContentLayout = Utility:Create("UIListLayout", {
        Parent = tab.Content,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 12)
    })
    
    ContentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tab.Content.CanvasSize = UDim2.new(0, 0, 0, ContentLayout.AbsoluteContentSize.Y + 30)
    end)
    
    -- Tab Selection Logic
    tab.Button.MouseEnter:Connect(function()
        if self.CurrentTab ~= tab then
            Utility:Tween(tab.Button, {BackgroundColor3 = Theme.ElementHover, TextColor3 = Theme.Text})
        end
    end)
    
    tab.Button.MouseLeave:Connect(function()
        if self.CurrentTab ~= tab then
            Utility:Tween(tab.Button, {BackgroundColor3 = Theme.Sidebar, TextColor3 = Theme.TextDark})
        end
    end)
    
    tab.Button.MouseButton1Click:Connect(function()
        if self.CurrentTab then
            self.CurrentTab.Content.Visible = false
            Utility:Tween(self.CurrentTab.Button, {BackgroundColor3 = Theme.Sidebar, TextColor3 = Theme.TextDark})
            Utility:Tween(self.CurrentTab.Indicator, {Size = UDim2.new(0, 3, 0, 0)})
        end
        
        self.CurrentTab = tab
        tab.Content.Visible = true
        Utility:Tween(tab.Button, {BackgroundColor3 = Theme.ElementBg, TextColor3 = Theme.Accent})
        Utility:Tween(Indicator, {Size = UDim2.new(0, 3, 0, 20)})
    end)
    
    tab.Indicator = Indicator
    
    if not self.CurrentTab then
        self.CurrentTab = tab
        tab.Content.Visible = true
        tab.Button.BackgroundColor3 = Theme.ElementBg
        tab.Button.TextColor3 = Theme.Accent
        Indicator.Size = UDim2.new(0, 3, 0, 20)
    end
    
    -- Component Methods
    function tab:CreateSection(titleText)
        local sec = Utility:Create("TextLabel", {
            Parent = tab.Content,
            Size = UDim2.new(1, 0, 0, 25),
            BackgroundTransparency = 1,
            Text = titleText,
            TextColor3 = Theme.Accent,
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left
        })
        return sec
    end
    
    function tab:CreateButton(options)
        options = options or {}
        local bName = options.Name or "Button"
        local cb = options.Callback or function() end
        
        local btn = Utility:Create("TextButton", {
            Parent = tab.Content,
            Size = UDim2.new(1, 0, 0, 45),
            BackgroundColor3 = Theme.ElementBg,
            AutoButtonColor = false,
            Text = "",
            ClipsDescendants = true
        })
        Utility:Create("UICorner", {Parent = btn, CornerRadius = UDim.new(0, 6)})
        local Stroke = Utility:Create("UIStroke", {Parent = btn, Color = Theme.Stroke})
        
        Utility:Create("TextLabel", {
            Parent = btn,
            Size = UDim2.new(1, -20, 1, 0),
            Position = UDim2.new(0, 15),
            BackgroundTransparency = 1,
            Text = bName,
            TextColor3 = Theme.Text,
            TextSize = 14,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left
        })
        
        btn.MouseEnter:Connect(function()
            Utility:Tween(btn, {BackgroundColor3 = Theme.ElementHover})
            Utility:Tween(Stroke, {Color = Theme.Accent})
        end)
        btn.MouseLeave:Connect(function()
            Utility:Tween(btn, {BackgroundColor3 = Theme.ElementBg})
            Utility:Tween(Stroke, {Color = Theme.Stroke})
        end)
        
        btn.MouseButton1Click:Connect(function()
            -- Ripple effect
            local ms = Mouse
            local ripple = Utility:Create("Frame", {
                Parent = btn,
                BackgroundColor3 = Theme.Accent,
                BackgroundTransparency = 0.6,
                Size = UDim2.new(0, 0, 0, 0),
                Position = UDim2.new(0, ms.X - btn.AbsolutePosition.X, 0, ms.Y - btn.AbsolutePosition.Y),
                AnchorPoint = Vector2.new(0.5, 0.5)
