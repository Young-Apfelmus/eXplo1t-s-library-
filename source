        Utility:Create("TextLabel", {
            Parent = frm,
            Size = UDim2.new(1, -20, 0, 30),
            Position = UDim2.new(0, 15, 0, 5),
            BackgroundTransparency = 1,
            Text = sName,
            TextColor3 = Theme.Text,
            TextSize = 14,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left
        })
        
        local ValBox = Utility:Create("TextBox", {
            Parent = frm,
            Size = UDim2.new(0, 60, 0, 20),
            Position = UDim2.new(1, -75, 0, 10),
            BackgroundColor3 = Theme.Background,
            Text = tostring(val),
            TextColor3 = Theme.Accent,
            TextSize = 13,
            Font = Enum.Font.GothamBold
        })
        Utility:Create("UICorner", {Parent = ValBox, CornerRadius = UDim.new(0, 4)})
        Utility:Create("UIStroke", {Parent = ValBox, Color = Theme.Stroke})
        
        local SldBg = Utility:Create("TextButton", {
            Parent = frm,
            Size = UDim2.new(1, -30, 0, 6),
            Position = UDim2.new(0, 15, 0, 40),
            BackgroundColor3 = Theme.Background,
            AutoButtonColor = false,
            Text = ""
        })
        Utility:Create("UICorner", {Parent = SldBg, CornerRadius = UDim.new(1, 0)})
        Utility:Create("UIStroke", {Parent = SldBg, Color = Theme.Stroke})
        
        local SldFill = Utility:Create("Frame", {
            Parent = SldBg,
            Size = UDim2.new((val - min) / (max - min), 0, 1, 0),
            BackgroundColor3 = Theme.Accent
        })
        Utility:Create("UICorner", {Parent = SldFill, CornerRadius = UDim.new(1, 0)})
        
        -- Glow
        local Glow = Utility:Create("ImageLabel", {
            Parent = SldFill,
            Size = UDim2.new(1, 20, 1, 20),
            Position = UDim2.new(0, -10, 0, -10),
            BackgroundTransparency = 1,
            Image = "rbxassetid://5028857084",
            ImageColor3 = Theme.Accent,
            ImageTransparency = 0.5,
            ZIndex = 0
        })
        
        local dragging = false
        
        local function Update(input)
            local rawX = input.Position.X - SldBg.AbsolutePosition.X
            local pct = math.clamp(rawX / SldBg.AbsoluteSize.X, 0, 1)
            local trueVal = min + (pct * (max - min))
            val = math.floor(trueVal / incr + 0.5) * incr
            val = math.clamp(val, min, max)
            
            local finalPct = (val - min) / (max - min)
            Utility:Tween(SldFill, {Size = UDim2.new(finalPct, 0, 1, 0)}, 0.1)
            ValBox.Text = tostring(val)
            cb(val)
        end
        
        SldBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                Update(input)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                Update(input)
            end
        end)
        
        ValBox.FocusLost:Connect(function()
            local n = tonumber(ValBox.Text)
            if n then
                val = math.clamp(math.floor(n / incr + 0.5) * incr, min, max)
                local pct = (val - min) / (max - min)
                Utility:Tween(SldFill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.2)
                ValBox.Text = tostring(val)
                cb(val)
            else
                ValBox.Text = tostring(val)
            end
        end)
    end
    
