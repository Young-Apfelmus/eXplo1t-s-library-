    function tab:CreateSlider(options)
        options = options or {}
        local sName = options.Name or "Slider"
        local min = options.Range and options.Range[1] or 0
        local max = options.Range and options.Range[2] or 100
        local val = options.CurrentValue or min
        local incr = options.Increment or 1
        local suffix = options.Suffix or ""
        local cb = options.Callback or function() end
        
        local frm = Utility:Create("Frame", {
            Parent = tab.Content,
            Size = UDim2.new(1, 0, 0, 60),
