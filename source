            SatGrad.Color = ColorSequence.new(Color3.new(1,1,1), Color3.fromHSV(ColorH, 1, ColorV))
            ValGrad.Color = ColorSequence.new(Color3.new(0,0,0), Color3.fromHSV(ColorH, ColorS, 1))
            cb(c)
        end
        
        local function attachSlider(bg, cursor, updateVar)
            local dragging = false
            bg.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
